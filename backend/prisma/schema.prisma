generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  password      String // not for manya
  name          String
  avatarUrl     String?
  globalRole    GlobalRole      @default(USER)
  refreshToken  String? // not for manya
  auditLogs     AuditLog[] // no linking to frontend
  comments      Comment[]
  notifications Notification[]
  projects      ProjectMember[]
  assignedTasks Task[]          @relation("Assignee") // not for manya
  reportedTasks Task[]          @relation("Reporter") // not for manya
}

model Project {
  id          String          @id @default(uuid())
  name        String
  description String?
  isArchived  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  boards      Board[]
  members     ProjectMember[]
}

model ProjectMember {
  id        String      @id @default(uuid())
  userId    String
  projectId String
  role      ProjectRole
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model Board {
  id               String   @id @default(uuid())
  name             String
  projectId        String
  storyColumnId    String?
  workflowColumnIds String   @default("[]")
  todoColumnId     String?
  inProgressColumnId String?
  resolvedColumnId String?
  closedColumnId   String?
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns          Column[]
  tasks            Task[]
}

model Column {
  id       String @id @default(uuid())
  name     String
  order    Int
  wipLimit Int?
  boardId  String
  board    Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks    Task[]
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  type        TaskType
  priority    Priority
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  resolvedAt  DateTime?
  closedAt    DateTime?
  boardId     String
  columnId    String
  reporterId  String
  assigneeId  String?
  parentId    String?
  auditLogs   AuditLog[]
  comments    Comment[]
  parent      Task?      @relation("TaskHierarchy", fields: [parentId], references: [id])
  children    Task[]     @relation("TaskHierarchy") // only story can have children
  assignee    User?      @relation("Assignee", fields: [assigneeId], references: [id])
  reporter    User       @relation("Reporter", fields: [reporterId], references: [id])
  column      Column     @relation(fields: [columnId], references: [id])
  board       Board      @relation(fields: [boardId], references: [id], onDelete: Cascade) // what about status of a task, would it be deriver from columnId?, i am using columnName for status
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  authorId  String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  action    String
  oldValue  String?
  newValue  String?
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum GlobalRole {
  GLOBAL_ADMIN
  USER
}

enum ProjectRole {
  PROJECT_ADMIN
  PROJECT_MEMBER
  PROJECT_VIEWER
}

enum TaskType {
  STORY
  TASK
  BUG
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
